<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RestaurantManagement.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap-Morph.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RestaurantManagement.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    Spice Garden Restaurant
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">

                         
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        @{
                            var role = Context.Session.GetString("UserRole")?.ToLower();
                            var userId = Context.Session.GetInt32("UserID");
                        }

                        
                        @if (role == "admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Categories" asp-action="Index">
                                    Categories
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="MenuItem" asp-action="Index">
                                    Menu Items
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="RestaurantTable" asp-action="Index">
                                    Tables
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Reservation" asp-action="Index">
                                    Reservations
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="AdminManagement" asp-action="Index">
                                    Staff
                                </a>
                            </li>
                        }

                        
                        @if (role == "customer")
                        {

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Categories" asp-action="Index">
                                    Categories
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="MenuItem" asp-action="Index">
                                    Menu
                                </a>
                            </li>

                            


                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="CustomerOrder"
                                   asp-action="Checkout"
                                   asp-route-dataId="-1">
                                    CheckOut
                                </a>
                            </li>

                             

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="CustomerOrder"
                                   asp-action="MyOrders">
                                    Order History
                                </a>
                            </li>


                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Feedback"
                                   asp-action="Create">
                                      Feedback
                                </a>
                            </li>

                           <li class="nav-item">
    <a class="nav-link text-white"
       asp-controller="Feedback"
       asp-action="MyFeedback">
        View Feedback
    </a>
</li>

                             
                        }

                    </ul>

                    <!-- RIGHT SIDE -->
                    <ul class="navbar-nav ms-auto">

                        @if (userId == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    Hello @Context.Session.GetString("Username")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <p class="text-primary"> 
            &copy; 2026 - Restaurant Management System <a asp-area="" asp-controller="Home" asp-action="Privacy"> </a></p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
