@model List<RestaurantManagement.Entities.RestaurantTable>

<partial name="_Message" />

<div class="row pt-4">
    <div class="col-6">
        <h2>Manage Restaurant Tables</h2>
    </div>

    <div class="col-6 text-end">
        <a class="btn btn-outline-info"
           asp-action="Detail"
           asp-controller="RestaurantTable"
           asp-route-dataId="-1">
            <i class="bi bi-plus-circle-fill"></i> &nbsp; Add New Table
        </a>
    </div>
</div>

<hr />

<div class="row pt-2">
    <div class="col-12">

        <table class="table table-bordered table-hover">
            <thead>
                <tr class="table-info">
                    <th>ID</th>
                    <th>Table Number</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th>Updated By</th>
                    <th style="width:200px">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr class="table-secondary text-center">
                        <td colspan="6">No record found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ID</td>
                            <td>@item.Table_number</td>
                            <td>@item.Capacity</td>
                            <td>
                                @if (item.Status == "Available")
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else if (item.Status == "Occupied")
                                {
                                    <span class="badge bg-danger">Occupied</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">@item.Status</span>
                                }
                            </td>
                            <td>@item.Updated_by</td>

                            <td>
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="Detail"
                                   asp-controller="RestaurantTable"
                                   asp-route-dataId="@item.ID">
                                    <i class="bi bi-pencil-square"></i> &nbsp; Edit
                                </a>

                                &nbsp;

                                <a onclick="return confirm('Are you sure?');"
                                   class="btn btn-sm btn-outline-danger"
                                   asp-action="Delete"
                                   asp-controller="RestaurantTable"
                                   asp-route-dataId="@item.ID">
                                    <i class="bi bi-trash3"></i> &nbsp; Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>

        </table>

    </div>
</div>