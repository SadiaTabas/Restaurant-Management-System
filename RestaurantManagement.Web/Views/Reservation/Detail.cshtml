@model RestaurantManagement.Entities.Reservation

<partial name="_Message" />

<div class="container border mt-4 pt-4">
    <div class="row">
        <div class="col-12">
            @if (Model.ID == 0)
            {
                <h2>Add New Reservation</h2>
            }
            else
            {
                <h2>Update Reservation# @Model.ID</h2>
            }
        </div>
        <hr />
    </div>

    <form method="post" asp-action="Detail" asp-controller="Reservation">
        <input type="hidden" asp-for="ID" />

        
        <div class="row mb-3">
            <label asp-for="Customer_ID" class="form-label">Customer</label>
            <select asp-for="Customer_ID" asp-items="@ViewBag.CustomerList" class="form-select">
                <option disabled="disabled" selected="selected">-- Select Customer --</option>
            </select>
            <span asp-validation-for="Customer_ID" class="text-danger"></span>
        </div>

        
        <div class="row mb-3">
            <label asp-for="Table_ID" class="form-label">Table</label>
            <select asp-for="Table_ID" asp-items="@ViewBag.TableList" class="form-select">
                <option disabled="disabled" selected="selected">-- Select Table --</option>
            </select>
            <span asp-validation-for="Table_ID" class="text-danger"></span>
        </div>

       
        <div class="row mb-3">
            <label asp-for="Reservation_time" class="form-label"></label>
            <input asp-for="Reservation_time" class="form-control" type="datetime-local" />
            <span asp-validation-for="Reservation_time" class="text-danger"></span>
        </div>

       
        <div class="row mb-3">
            <label asp-for="Number_Of_people" class="form-label"></label>
            <input asp-for="Number_Of_people" class="form-control" type="number" />
            <span asp-validation-for="Number_Of_people" class="text-danger"></span>
        </div>

        
        <div class="row mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="Pending">Pending</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-6">
                <button type="submit" class="btn btn-outline-success">
                    <i class="bi bi-save"></i>&nbsp;Submit
                </button>
                &nbsp;
                <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-warning">
                    <i class="bi bi-arrow-left"></i>&nbsp;Back To Home
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}