@model List<RestaurantManagement.Entities.MenuItem>
<partial name="_Message" />
@{
    var role = Context.Session.GetString("UserRole")?.ToLower();
}

<div class="row pt-4">
    <div class="col-6">
        <h2>Manage Menu Items</h2>
    </div>
    @if (role == "admin")
    {
        <div class="col-6 text-end">
            <a class="btn btn-outline-info"
               asp-action="Detail"
               asp-controller="MenuItem"
               asp-route-dataId="-1">
                <i class="bi bi-plus-circle-fill"></i> &nbsp; Add New Menu Item
            </a>
        </div>
    }
</div>
<hr />

<div class="row pt-2">
    <div class="col-12">
        <table class="table table-bordered table-hover">
            <thead>
                <tr class="table-info">
                    @if (role == "admin")
                    {
                        <th>ID</th>
                    }
                    <th>Category</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Active</th>
                    <th>Quantity</th>
                    <th>Picture</th>
                    <th>Add to Cart</th>

                    @if (role == "admin")
                    {
                        <th style="width:200px">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr class="table-secondary text-center">
                        <td colspan="8">No record found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            @if (role == "admin")
                            {
                                <td>@item.ID</td>
                            }
                            <td>@item.Category?.Name</td>
                            <td>@item.Name</td>
                            <td>@item.Price</td>
                             
                            <td>
                                @if (item.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>@item.Quantity</td>
                            <td>
                                <img src="@item.Image_URL"
                                     alt="Food Image"
                                     class="img-thumbnail"
                                     style="width:80px; height:80px;" />
                            </td>
                          <td>  <a asp-action="AddToCart"
                               asp-route-id="@item.ID"
                               class="btn btn-sm btn-success">
                                Add To Cart
                            </a>

                            </td>

                            <td>
                                @if (role == "admin")
{
    <a class="btn btn-sm btn-outline-secondary"
       asp-action="Detail"
       asp-controller="MenuItem"
       asp-route-dataId="@item.ID">
        <i class="bi bi-pencil-square"></i> &nbsp; Edit
    </a>
                                
                                    <a onclick="return confirm('Are you sure?');"
                                       class="btn btn-sm btn-outline-danger"
                                       asp-action="Delete"
                                       asp-controller="MenuItem"
                                       asp-route-dataId="@item.ID">
                                        <i class="bi bi-trash3"></i> &nbsp; Delete
                                    </a>



                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <a class="badge bg-success"

            asp-controller="CustomerOrder"
               asp-action="Checkout">
                
                Proceed to Checkout
            </a>

        </div>
    </div>
 