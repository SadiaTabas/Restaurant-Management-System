@model List<RestaurantManagement.Entities.Customer>
<partial name="_Message" />


<div class="text-center">
    <h1 class="display-4">Welcome To Our Restaurant </h1>
    <p class="text-primary"> Delicious food, easy table booking, and fast service.</p>
</div>

<div class="row pt-4">
    <div class="col-6">
        <h2>Manage Customers</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-outline-info" asp-action="Detail" asp-controller="Customer" asp-route-dataId="-1">
            <i class="bi bi-plus-circle-fill"></i> &nbsp; Add New Customer
        </a>
       </div>
       </div>
       <hr />

<div class="row pt-2">
 <div class="col-12">
  <table class="table table-bordered table-hover">
      <thead>
                <tr class="table-info">
                    <th>ID</th>
                    <th>Address</th>
                    <th>Total Orders</th>
                    <th>Created At</th>
                    <th style="width:200px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr class="table-secondary text-center">
                        <td colspan="5">No record found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Address</td>
                            <td>@item.TotalOrders</td>
                            <td>@item.CreatedAt</td>
                            <td>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Detail" asp-controller="Customer" asp-route-dataId="@item.Id">
                                    <i class="bi bi-pencil-square"></i> &nbsp; Edit
                                </a>
                                &nbsp;
                                <a onclick="return confirm('Are you sure?');" class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-controller="Customer" asp-route-dataId="@item.Id">
                                    <i class="bi bi-trash3"></i> &nbsp; Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>