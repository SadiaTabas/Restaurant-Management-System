@model List<RestaurantManagement.Entities.Feedback>

<div class="container mt-4">

    <h3>My Feedback</h3>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Rating</th>
                <th>Comments</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center">No feedback found</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Ratings</td>
                        <td>@item.Comments</td>
                        <td>@item.Created_at</td>
                    </tr>
                }
            }

        </tbody>

    </table>

</div>