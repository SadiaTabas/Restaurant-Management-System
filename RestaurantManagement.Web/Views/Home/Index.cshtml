@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid p-0">

    <!-- Restaurant Banner -->
    <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1600"
         class="img-fluid w-100"
         style="height:500px; object-fit:cover;"
         alt="Spice Garden Restaurant">

    <!-- Welcome Section -->
    <div class="text-center py-5">

        <h1 class="display-3 fw-bold text-danger">
            Spice Garden Restaurant
        </h1>

        <p class="lead mt-3">
            Experience the perfect blend of delicious food, elegant ambiance,
            and outstanding service.
        </p>

        <p class="text-muted fs-5">
            Whether you're planning a family dinner, a casual lunch,
            or a special celebration, Spice Garden Restaurant is the perfect place.
        </p>

        <hr class="w-50 mx-auto my-4">

        <h4 class="text-dark">
            Please Login or Register from the navigation menu to continue.
        </h4>

    </div>

    <!-- Features -->
    <div class="container mb-5">
        <div class="row text-center">

            <div class="col-md-4 mb-4">
                <div class="card shadow border-0">
                    <div class="card-body">
                        <h3>🍽 Fresh Cuisine</h3>
                        <p>
                            Prepared daily using fresh ingredients and authentic recipes.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow border-0">
                    <div class="card-body">
                        <h3>⭐ Premium Service</h3>
                        <p>
                            Friendly staff dedicated to making every visit memorable.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow border-0">
                    <div class="card-body">
                        <h3>🏆 Customer Satisfaction</h3>
                        <p>
                            Delivering quality food and an exceptional dining experience.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>